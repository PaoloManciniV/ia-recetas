# ============================================================
#  .env.example  -->  Ejemplo de variables de entorno
# ============================================================
# COPIA este archivo y renómbralo a ".env", luego pon tus valores.
# El archivo ".env" NUNCA se sube a Git (está en .gitignore).
# ============================================================

# --- Base de datos ---
# Por defecto usamos SQLite (no hay que instalar nada):
DATABASE_URL=sqlite:///./recetas.db

# Para producción con MySQL + Docker, usa algo como esto:
# DATABASE_URL=mysql+pymysql://usuario:contrasena@db:3306/recetas

# --- Login (JWT) ---
# Clave secreta para firmar los tokens. CÁMBIALA por algo largo y único.
SECRET_KEY=cambia-esto-por-una-clave-larga-y-secreta

# --- LLM (lo usará el equipo en la funcionalidad #3) ---
# OPENROUTER_API_KEY=tu_api_key_aqui
